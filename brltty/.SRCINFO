pkgname = brltty
	install = brltty.install
	depends = alsa-lib
	depends = libasound.so
	depends = at-spi2-core
	depends = bash
	depends = bluez-libs
	depends = dbus
	depends = libdbus-1.so
	depends = espeak-ng
	depends = expat
	depends = libexpat.so
	depends = glib2
	depends = libgio-2.0.so
	depends = libglib-2.0.so
	depends = libgobject-2.0.so
	depends = glibc
	depends = gpm
	depends = libgpm.so
	depends = icu
	depends = libicuuc.so
	depends = libcap
	depends = liblouis
	depends = libspeechd
	depends = libxaw
	depends = libxt
	depends = libx11
	depends = libxfixes
	depends = libxtst
	depends = ncurses
	depends = libncursesw.so
	depends = pcre2
	depends = polkit
	depends = systemd-libs
	depends = libsystemd.so
	optdepends = brltty-udev-generic: for initializing brltty with generic USB devices
	optdepends = dracut-brltty: for dracut modules
	optdepends = java-brltty: for Java bindings
	optdepends = ocaml-brltty: for OCaml bindings
	optdepends = python-brltty: for Python bindings
	optdepends = speech-dispatcher: speech-dispatcher driver
	optdepends = tcl-brltty: for TCL bindings
	provides = libbrlapi.so
	backup = etc/brltty.conf
	backup = etc/X11/xinit/xinitrc.d/90xbrlapi

pkgname = brltty-udev-generic
	pkgdesc = Generic udev rules for brltty
	depends = brltty=6.9

pkgname = dracut-brltty
	pkgdesc = Braille display driver for Linux/Unix - dracut modules
	groups = dracut-modules
	depends = bash
	depends = brltty=6.9
	depends = dracut

pkgname = java-brltty
	pkgdesc = Braille display driver for Linux/Unix - java bindings
	depends = brltty=6.9
	depends = java-runtime

pkgname = ocaml-brltty
	pkgdesc = Braille display driver for Linux/Unix - OCaml bindings
	depends = brltty=6.9
	depends = glibc
	depends = ocaml

pkgname = python-brltty
	pkgdesc = Braille display driver for Linux/Unix - Python bindings
	depends = brltty=6.9
	depends = glibc
	depends = python

pkgname = tcl-brltty
	pkgdesc = Braille display driver for Linux/Unix - TCL integration
	depends = brltty=6.9
	depends = glibc
	depends = tcl
