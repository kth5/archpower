pkgname=gegl
pkgver=0.4.70
pkgrel=2
pkgdesc='Graph based image processing framework'
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url='https://www.gegl.org/'
license=('GPL-3.0-or-later OR LGPL-3.0-or-later')
depends=('babl' 'libbabl-0.1.so'
         'cairo' 'libcairo.so'
         'gdk-pixbuf2' 'libgdk_pixbuf-2.0.so'
         'glib2' 'libgio-2.0.so' 'libglib-2.0.so' 'libgmodule-2.0.so' 'libgobject-2.0.so'
         'glibc'
         'jasper' 'libjasper.so'
         'json-glib' 'libjson-glib-1.0.so'
         'lcms2' 'liblcms2.so'
         'lensfun' #'liblensfun.so'
         'libgcc' 'libgcc_s.so'
         'libgomp.so' 'libgomp.so'
         'libjpeg-turbo' 'libjpeg.so'
         'libpng' 'libpng16.so'
         'libraw' #'libraw.so'
         'librsvg' 'librsvg-2.so'
         'libspiro' #'libspiro.so'
         'libstdc++' 'libstdc++.so'
         'libtiff' 'libtiff.so'
         'libwebp' 'libwebp.so'
         'openexr' #'libOpenEXR-3_4.so'
         'pango' 'libpango-1.0.so' 'libpangocairo-1.0.so'
         'poppler-glib' 'libpoppler-glib.so'
         'suitesparse' #'libumfpack.so'
)
makedepends=('ffmpeg' 'git' 'gobject-introspection' 'libgexiv2' 'meson' 'python-gobject' 'sdl2'
             'vala' 'gi-docgen')
optdepends=('ffmpeg: FFmpeg Frame Loader and FFmpeg Frame Saver plugins'
            'graphviz: for gegl-introspect'
            'sdl2: SDL2 Display plugin')
provides=('libgegl-0.4.so' 'libgegl-npd-0.4.so' 'libgegl-sc-0.4.so')
source=("git+https://gitlab.gnome.org/GNOME/gegl.git#tag=GEGL_${pkgver//./_}")
sha256sums=('2d1d8e77b18be3db417b37247b80e798d51cfc2ac27cc881f30089f9723899df')

pkgver() {
  cd "${pkgname}"
  git describe --tags | sed 's/^GEGL_//;s/_$//;s/_/./g;s/-/+/g'
}

prepare() {
  cd "${pkgname}"

  # Build fix for ffmpeg 8
  git cherry-pick -n eda8ba51786f197b72265eafcdab407d91ec9c70
}

build() {
  mkdir -p build
  cd build
  arch-meson ../"${pkgname}" \
    -Dworkshop=true \
    -Dmrg=disabled \
    -Dmaxflow=disabled \
    -Dlua=disabled
  ninja
}

check() {
  cd build
  ninja test || :
}

package() {
  cd build
  DESTDIR="${pkgdir}" ninja install
}
