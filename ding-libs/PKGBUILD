pkgname=ding-libs
pkgver=0.7.0
pkgrel=1
pkgdesc="\"DING is not GNU\" helper libraries for SSSD and FreeIPA"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url="https://github.com/SSSD/ding-libs"
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=('glibc')
makedepends=('doxygen')
checkdepends=('check')
# https://github.com/SSSD/ding-libs/releases/download/0.7.0/ding-libs-0.7.0.tar.gz.sha256sum
source=(https://github.com/SSSD/ding-libs/releases/download/$pkgver/$pkgname-$pkgver.tar.gz{,.asc})
sha256sums=('5df2f202f892b4c1a6caf87f0056398a8288b281da9d7e65cd7637978ec20ef3'
            'SKIP')
validpgpkeys=('930201AAB42DD1947210B7838D7326351A726211') # Alexey Tikhonov <atikhono@redhat.com>

build() {
  cd $pkgname-$pkgver
  ./configure --prefix=/usr --disable-static
  make all docs
}

check() {
  cd $pkgname-$pkgver
  make check
}

package() {
  cd $pkgname-$pkgver
  make DESTDIR="$pkgdir/" install
} 
