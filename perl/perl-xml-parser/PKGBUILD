# POWER Maintainer: Alexander Baldeck <alex.bldck@gmail.com>
# Maintainer: Eric Bélanger <eric@archlinux.org>

pkgname=perl-xml-parser
pkgver=2.52
pkgrel=1
pkgdesc="Expat-based XML parser module for perl"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
license=('GPL-1.0-or-later' 'Artistic-1.0-Perl')
url="https://github.com/cpan-authors/XML-Parser"
depends=('perl-file-sharedir' 'perl-libwww' 'expat')
makedepends=('git' 'perl-file-sharedir-install' 'perl-devel-checklib')
options=('!emptydirs')
source=("git+https://github.com/cpan-authors/XML-Parser.git#tag=${pkgver}")
sha512sums=('66937c669c7ecbb6fe1cc2c6dc2d46d5c68c697ca8488d5b6b6580fa8eb08bcdcb292d5ceda9e829c20b8c66993f50e7d6f97968840ef41d9d123801bacfe253')

prepare() {
  cd XML-Parser

  # Fix AllocTracker feature detection with current libexpat headers
  git cherry-pick -n 0cb1959

}

build() {
  cd XML-Parser
  perl Makefile.PL INSTALLDIRS=vendor
  make
}

check() {
  cd XML-Parser
  make test
}

package() {
  cd XML-Parser
  make DESTDIR="${pkgdir}" install
}
