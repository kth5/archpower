pkgname=giflib
pkgver=6.1.2
pkgrel=1
pkgdesc='Library for reading and writing gif images'
arch=(x86_64 powerpc64le powerpc64 powerpc riscv64 espresso)
url='http://giflib.sourceforge.net/'
license=('MIT')
depends=('glibc')
makedepends=(
  'docbook-xml'
  'docbook-xsl'
  'git'
  'imagemagick'
  'xmlto'
)
provides=('libgif.so')
source=("${pkgname}::git+https://git.code.sf.net/p/giflib/code#tag=${pkgver}")
sha512sums=('afae74bcd4858237a86a4fd26409f1d8b1c9075b3482a56353a773def4f608b37e17b1fc1b5cd81a8a907b171aea3cc3dfc8311b63905d022208b73ed8618a67')

build() {
  cd ${pkgname}
  CFLAGS="${CFLAGS/_FORTIFY_SOURCE=3/_FORTIFY_SOURCE=2}"
  make
}

check() {
  cd ${pkgname}
  make check
}

package() {
  cd ${pkgname}
  make PREFIX=/usr DESTDIR="${pkgdir}" install
  install -vDm 644 COPYING -t "${pkgdir}/usr/share/licenses/${pkgname}"
}

