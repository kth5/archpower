pkgname = linux-g4
	pkgdesc = The Linux (powerpc / optimized for G4 and later) kernel and modules
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = wireless-regdb: to set the correct wireless channels of your country
