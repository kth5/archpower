pkgname=aspell-pl
pkgver=20260301
pkgrel=1
pkgdesc='Polish dictionary for aspell'
arch=('any')
url="https://www.sjp.pl/slownik/en/"
license=('GPL' 'LGPL' 'MPL' 'CC SA' 'Apache')
depends=('aspell')
source=(https://sjp.pl/sl/ort/sjp-aspell6-pl-6.0_$pkgver-0.tar.bz2)
sha256sums=('247389ae46fe8320073c6994a9f56aa6f1233c5f47b433747db56a8775ffe9cf')

build() {
  cd aspell6-pl-6.0_$pkgver-0

  ./configure
  make
}

package() {
  cd aspell6-pl-6.0_$pkgver-0

  make DESTDIR="$pkgdir" install
}
