pkgname=libgsystemservice
pkgver=0.3.0
pkgrel=2
pkgdesc="Common components for building D-Bus system services"
url="https://gitlab.gnome.org/pwithnall/libgsystemservice"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
license=(LGPL-2.1-or-later)
depends=(
  glib2
  glibc
  libgcc
  polkit
  systemd-libs
)
makedepends=(
  git
  glib2-devel
  gtk-doc
  meson
)
provides=(libgsystemservice-0.so)
source=("git+https://gitlab.gnome.org/pwithnall/libgsystemservice.git#tag=${pkgver}")
b2sums=('08db1b4568afa0065346c47c0956f545d4d9fb5e04608667942bc5a10c9293dcaaa2cd7b15a83f5ac1b70e78b34374c863ff9b18989f363beab1b0468149f5b9')

prepare() {
  cd $pkgname
}

build() {
  arch-meson $pkgname build
  meson compile -C build
}

check() (
  meson test -C build --print-errorlogs
)

package() {
  meson install -C build --destdir "$pkgdir"
}

