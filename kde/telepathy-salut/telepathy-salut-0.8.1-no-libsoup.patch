From 11e3e5c5b994a7432dbe4fa6e149677fa7f90800 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Ball=C3=B3=20Gy=C3=B6rgy?= <ballogyor@gmail.com>
Date: Wed, 29 Oct 2025 22:18:59 +0100
Subject: [PATCH] Disable file transfer manager (removes libsoup dependency)

---
 configure.ac           | 1 -
 lib/gibber/Makefile.am | 4 ----
 src/Makefile.am        | 4 ----
 src/connection.c       | 7 -------
 src/protocol.c         | 2 --
 5 files changed, 18 deletions(-)

diff --git a/configure.ac b/configure.ac
index 9e9fd319..e6b52e12 100644
--- a/configure.ac
+++ b/configure.ac
@@ -245,7 +245,6 @@ AS_IF([test x$with_backend = xno],
 ])
 
 dnl Check for libsoup
-PKG_CHECK_MODULES(LIBSOUP, [libsoup-2.4])
 AC_SUBST(LIBSOUP_CFLAGS)
 AC_SUBST(LIBSOUP_LIBS)
 
diff --git a/lib/gibber/Makefile.am b/lib/gibber/Makefile.am
index 2b9e33fd..445d0fce 100644
--- a/lib/gibber/Makefile.am
+++ b/lib/gibber/Makefile.am
@@ -36,10 +36,6 @@ HANDWRITTEN_SOURCES =             \
   gibber-r-multicast-sender.h     \
   gibber-linklocal-transport.c    \
   gibber-linklocal-transport.h    \
-  gibber-file-transfer.c          \
-  gibber-file-transfer.h          \
-  gibber-oob-file-transfer.c      \
-  gibber-oob-file-transfer.h      \
   gibber-listener.c               \
   gibber-listener.h               \
   gibber-sockets.c                \
diff --git a/src/Makefile.am b/src/Makefile.am
index e1d10e0d..7d1f9a85 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -37,10 +37,6 @@ CORE_SOURCES =                                          \
     roomlist-manager.c                            \
     roomlist-manager.h                            \
     muc-channel.c                                 \
-    ft-manager.c                                  \
-    ft-manager.h                                  \
-    file-transfer-channel.c                       \
-    file-transfer-channel.h                       \
     muc-channel.h                                 \
     muc-tube-dbus.c                               \
     muc-tube-dbus.h                               \
diff --git a/src/connection.c b/src/connection.c
index de434a91..215d5354 100644
--- a/src/connection.c
+++ b/src/connection.c
@@ -48,7 +48,6 @@
 #include "discovery-client.h"
 #include "im-manager.h"
 #include "muc-manager.h"
-#include "ft-manager.h"
 #include "contact.h"
 #include "roomlist-manager.h"
 #include "presence.h"
@@ -202,9 +201,6 @@ struct _SalutConnectionPrivate
   /* MUC channel manager */
   SalutMucManager *muc_manager;
 
-  /* FT channel manager */
-  SalutFtManager *ft_manager;
-
   /* Roomlist channel manager */
   SalutRoomlistManager *roomlist_manager;
 
@@ -3658,8 +3654,6 @@ salut_connection_create_channel_managers (TpBaseConnection *base)
    */
   priv->im_manager = salut_im_manager_new (self, priv->contact_manager);
 
-  priv->ft_manager = salut_ft_manager_new (self, priv->contact_manager);
-
 #ifndef USE_BACKEND_BONJOUR
   priv->muc_manager = salut_discovery_client_create_muc_manager (
       priv->discovery_client, self);
@@ -3674,7 +3668,6 @@ salut_connection_create_channel_managers (TpBaseConnection *base)
 
   g_ptr_array_add (managers, priv->im_manager);
   g_ptr_array_add (managers, priv->contact_manager);
-  g_ptr_array_add (managers, priv->ft_manager);
 #ifndef USE_BACKEND_BONJOUR
   g_ptr_array_add (managers, priv->muc_manager);
   g_ptr_array_add (managers, priv->roomlist_manager);
diff --git a/src/protocol.c b/src/protocol.c
index 2b805c85..5f191e0c 100644
--- a/src/protocol.c
+++ b/src/protocol.c
@@ -26,7 +26,6 @@
 
 #include "connection.h"
 #include "contact-manager.h"
-#include "ft-manager.h"
 #include "im-manager.h"
 #include "muc-manager.h"
 #include "roomlist-manager.h"
@@ -157,7 +156,6 @@ get_connection_details (TpBaseProtocol *self,
     {
       GType types[] = {
           SALUT_TYPE_CONTACT_MANAGER,
-          SALUT_TYPE_FT_MANAGER,
           SALUT_TYPE_IM_MANAGER,
           SALUT_TYPE_MUC_MANAGER,
           SALUT_TYPE_ROOMLIST_MANAGER,
-- 
