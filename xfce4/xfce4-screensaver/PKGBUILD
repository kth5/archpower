# Maintainer: Robin Candau <antiz@archlinux.org>

pkgname=xfce4-screensaver
pkgver=4.20.2
pkgrel=1
pkgdesc='Xfce Screensaver'
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url='https://docs.xfce.org/apps/screensaver/start'
license=('LGPL-2.1-only')
groups=('xfce4-goodies')
depends=('libxss' 'libxklavier' 'libwnck3' 'garcon' 'dbus-glib' 'python' 'python-gobject')
optdepends=('onboard: on screen keyboard for unlocking'
            'xscreensaver: additional themes')
makedepends=('git' 'glib2-devel' 'meson' 'ninja' 'xfce4-dev-tools' 'xmlto' 'xscreensaver')
backup=('etc/pam.d/xfce4-screensaver')
source=("git+https://gitlab.xfce.org/apps/xfce4-screensaver.git#tag=$pkgname-$pkgver")
sha256sums=('bc84a11d51fbc4222ca43831671de2935e759229d21ee7136443e7250c78498f')

build() {
  arch-meson "${pkgname}" build
  meson compile -C build
}

package() {
  meson install -C build --destdir "${pkgdir}"
}
