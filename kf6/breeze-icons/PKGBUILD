pkgname=breeze-icons
pkgver=6.27.0
pkgrel=1
pkgdesc='Breeze icon theme'
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url='https://develop.kde.org/products/frameworks/'
license=(LGPL-3.0-or-later
         LGPL-2.1-only)
depends=(glibc
         qt6-base)
makedepends=(extra-cmake-modules
             python-lxml)
groups=(kf6)
source=(https://download.kde.org/stable/frameworks/${pkgver%.*}/$pkgname-$pkgver.tar.xz{,.sig})
sha256sums=('bc8c2337802837ff1809269a8e4c4311b93e7e90c78ab4fe2a86cf5300ffd414'
            'SKIP')
validpgpkeys=(53E6B47B45CEA3E0D5B7457758D0EE648A48B3BB # David Faure <faure@kde.org>
              90A968ACA84537CC27B99EAF2C8DF587A6D4AAC1 # Nicolas Fella <nicolas.fella@kde.org>
              )

build() {
  cmake -B build -S $pkgname-$pkgver \
    -DBINARY_ICONS_RESOURCE=ON \
    -DBUILD_TESTING=OFF
  cmake --build build 1>/dev/null
}

package() {
  DESTDIR="$pkgdir" cmake --install build 1>/dev/null
}
