# POWER Maintainer: Alexander Baldeck <alex.bldck@gmail.com>
# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=python-orderly-set
pkgver=5.5.0
pkgrel=1
pkgdesc="A package containing multiple implementations of Ordered Set"
arch=('any')
url="https://github.com/seperman/orderly-set"
license=('MIT')
depends=('python')
makedepends=('python-flit-core' 'python-build' 'python-installer' 'python-wheel' 'git')
checkdepends=('python-pytest')
source=("git+https://github.com/seperman/orderly-set.git#tag=$pkgver")
sha512sums=('fb27802c9e1b85b86f1b1ad547579ceacc73967e7e2d0ef94478ed58c297215a890c9d93a19f019e3fac3de59ae9a71e6615e52dac5c1bb845698621f217f992')

build() {
  cd orderly-set
  python -m build --wheel --no-isolation
}

check() {
  cd orderly-set
  pytest
}

package() {
  cd orderly-set
  python -m installer --destdir="$pkgdir" dist/*.whl

  install -Dm644 MIT-LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}
