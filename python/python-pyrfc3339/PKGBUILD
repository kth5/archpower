# Maintainer: Felix Yan <felixonmars@archlinux.org>
# Contributor: Gordian Edenhofer <gordian.edenhofer[at]yahoo[dot]de>

pkgname=python-pyrfc3339
pkgver=2.1.0
pkgrel=1
pkgdesc="Parses and generates RFC 3339-compliant timestamps using Python datetime.datetime objects."
arch=(any)
license=('MIT')
url="https://github.com/kurtraschke/pyRFC3339"
depends=('python')
makedepends=('git' 'python-setuptools' 'python-setuptools-scm' 'python-build' 'python-installer' 'python-wheel')
checkdepends=('python-pytest')
source=("git+https://github.com/kurtraschke/pyRFC3339.git#tag=v$pkgver"
        4fa081a3.patch)
sha512sums=('bada030fc86d2e9e47890c08868205c60bc26d5ad14cb0465aa5f751bf869b97e026073e4afbda58173deed3b5f339b0fb0b0b419cd2055b6b9b063e7bd23b69'
            'ad1dc8066e9aa2881e57d11d012edbced8a790abd2eb4a7f0b06b668df3975e9d176fb87d752877e25b91579ac308fba8e400dcd0c44264e0a22416a9ed78ef8')

prepare() {
  cd pyRFC3339
  patch -p1 -i ../4fa081a3.patch # Fix doctest on Python 3.14+
}

build() {
  cd pyRFC3339
  python -m build --wheel --no-isolation
}

check() {
  cd pyRFC3339
  python -m venv --system-site-packages test-env
  test-env/bin/python -m installer dist/*.whl
  test-env/bin/python -m pytest --doctest-modules
}

package() {
  cd pyRFC3339
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -D -m644 LICENSE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.txt"
}
