pkgname=python-requestsexceptions
pkgver=1.4.0
pkgrel=14
pkgdesc="Import exceptions from potentially bundled packages in requests."
arch=(any)
url="https://github.com/openstack-infra/requestsexceptions"
license=('Apache-2.0')
depends=('python-requests')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel' 'python-pbr')
source=("git+https://github.com/openstack-infra/requestsexceptions.git#tag=$pkgver")
sha512sums=('27716d6bbf079b868cb8f1cbeb6881711366400f65e35f9ebe66fe9cc48147fa5e1542e033dabc517c1d66e135bb39df69d159f919d090a37f88c1bef42f9cf0')

build() {
  cd requestsexceptions
  python -m build --wheel --no-isolation
}

package() {
  cd requestsexceptions
  python -m installer --destdir="$pkgdir" dist/*.whl
}

