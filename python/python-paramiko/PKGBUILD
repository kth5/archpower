pkgname=python-paramiko
pkgver=5.0.0
pkgrel=1
pkgdesc="Python module that implements the SSH2 protocol"
url="https://github.com/paramiko/paramiko/"
license=('LGPL-2.1-only')
arch=(any)
depends=('python-bcrypt' 'python-cryptography' 'python-pynacl' 'python-invoke')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel' 'python-setuptools')
checkdepends=('python-pytest-relaxed' 'python-icecream')
source=(
  "git+https://github.com/paramiko/paramiko.git#tag=$pkgver"
)
sha512sums=('8ddb1c243e10f6d7c2ed666d616c74d9daec9ad311eb68eb5091276df2db482de5b157271a4ef8430ec467809ba341ca3bbd209c8a6bffd261ff4815981a7e83')

prepare() {
  cd paramiko
  # Devendor test setup
  sed -i "s/from invoke.vendor.lexicon import Lexicon/from lexicon import Lexicon/" tests/conftest.py
}

build() {
  cd paramiko
  python -m build --wheel --no-isolation
}

check() {
  cd paramiko
  LANG=en_US.UTF-8 pytest
}

package() {
  cd paramiko

  python -m installer --destdir="$pkgdir" dist/*.whl
}
