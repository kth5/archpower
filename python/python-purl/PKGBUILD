# POWER Maintainer: Alexander Baldeck <alex.bldck@gmail.com>
# Maintainer: Felix Yan <felixonmars@archlinux.org>

pkgname=python-purl
pkgver=1.6
pkgrel=8
pkgdesc="An immutable URL class for easy URL-building and manipulation"
arch=(any)
license=('MIT')
url="https://github.com/codeinthehole/purl"
depends=('python-six')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel' 'python-setuptools')
checkdepends=('python-pytest')
source=("git+https://github.com/codeinthehole/purl.git#tag=$pkgver")
sha512sums=('8cd0576964727eaab4da3461456287d093b3702d1ce295b4abe1ad468391e6ccae273cf5ac7a66b4fcfa5332aae4adb594cb780d080052fdcf3013310b93fbc1')

build() {
  cd purl
  python -m build --wheel --no-isolation
}

check() {
  cd purl
  python -m pytest
}

package() {
  cd purl
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
}
