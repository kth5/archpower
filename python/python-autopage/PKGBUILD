# Maintainer:

pkgname=python-autopage
pkgver=0.6.0
pkgrel=1
pkgdesc='A library to provide automatic paging for console output'
arch=(any)
url='https://github.com/zaneb/autopage'
license=('Apache-2.0')
depends=(python)
checkdepends=(python-pytest python-fixtures python-testtools)
makedepends=(python-build python-installer python-setuptools python-wheel)
source=(https://pypi.python.org/packages/source/a/autopage/autopage-$pkgver.tar.gz)
sha512sums=('f063100ee81bba9da967c1543acfa8d17658c0fdc4d63e8b0f50eea142b6dd08279347aa247f8bba5b5dbcd4904575c733860cae6df2e41fd5580bc0e6cbe983')

build() {
  cd autopage-$pkgver
  python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
  cd autopage-$pkgver
  unset LESS PAGER
  pytest -v -k 'not test_end_to_end.py'
}

package() {
  cd autopage-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
}
