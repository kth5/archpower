pkgname=python-platformdirs
pkgver=4.9.5
pkgrel=1
pkgdesc='A library to determine platform-specific system directories'
arch=(any)
url='https://github.com/tox-dev/platformdirs'
license=(MIT)
depends=(python)
makedepends=(
  git
  python-build
  python-installer
  python-hatchling
  python-hatch-vcs
)
checkdepends=(
  python-pytest
  python-pytest-mock
  python-appdirs
)
source=("$pkgname::git+$url#tag=$pkgver")
sha512sums=('105bb1b3599c19f22baa90adb96b4e4704c63eccfdeb5aa4a9a671f4a7807722096cacffda560eedf384008d872d1edf0379abe33c07b26c992975ea34f94b8b')
b2sums=('2c8c9d274afeb8c154df821817e0b0389ebae8f8cad79b642f3fe95a71c4520fbf2565bf79d3f1346c97c6bc8180d5ef663e7154c38ed740521f42279ff61b79')

build() {
  cd "$pkgname"

  python -m build --wheel --no-isolation
}

check() {
  cd "$pkgname"

  PYTHONPATH="$(pwd)/src" pytest -v
}

package() {
  cd "$pkgname"

  python -m installer --destdir="$pkgdir" dist/*.whl

  # license
  install -vDm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE
}
