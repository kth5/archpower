# Maintainer: Daniel M. Capella <polyzen@archlinux.org>
# Contributor: Otreblan <otreblain@gmail.com>

pkgname=python-pygls
_name=${pkgname#python-}
pkgver=2.1.1
pkgrel=1
pkgdesc='Pythonic generic implementation of the Language Server Protocol'
arch=(any)
url=https://github.com/openlawlibrary/pygls
license=(Apache-2.0)
depends=(
  python-attrs
  python-cattrs
  python-lsprotocol
)
makedepends=(
  git
  python-build
  python-installer
  python-poetry-core
)
checkdepends=(python-pytest-asyncio)
source=("git+$url.git#tag=v$pkgver")
b2sums=('f947b2e0cc890f0dff8d15a740ebb5772b68671b406444ac022a6bee5314b03a18c6936b7d03b9e9f432c4ce059f72ab830835916c85d90bef874791ecf419ca')

build() {
  cd "$_name"
  python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
  cd "$_name"
  PYTHONPATH="$PWD/$_name:$PYTHONPATH" pytest
}

package() {
  local site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  install -d "$pkgdir"/usr/share/licenses/$pkgname
  ln -s "$site_packages"/"$_name"-$pkgver.dist-info/licenses/LICENSE.txt \
    "$pkgdir"/usr/share/licenses/$pkgname

  cd "$_name"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
