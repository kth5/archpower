# POWER Maintainer: Alexander Baldeck <alex.bldck@gmail.com>
# Maintainer: Evangelos Foutras <foutrelis@archlinux.org>

pkgname=python-sphobjinv
_name=${pkgname#python-}
pkgver=2.4
pkgrel=1
pkgdesc="Manipulate and inspect Sphinx objects.inv files"
arch=(any)
url="https://github.com/bskinn/sphobjinv"
license=('MIT')
depends=('python' 'python-attrs' 'python-certifi' 'python-jsonschema')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel'
             'python-setuptools')
source=("git+https://github.com/bskinn/sphobjinv.git#tag=v$pkgver")
sha256sums=('39b54b804d541cb81735d02311b9b4bcaab8556c0bc74a1f0bf755f493d65f3d')

build() {
  cd "$_name"
  python -m build --wheel --no-isolation
}

package() {
  cd "$_name"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE.txt
}

