+static inline uint16_t
+r300_b5g6r5_swap_rb(uint16_t value)
+{
+    return ((value & 0xf800) >> 11) |
+           (value & 0x07e0) |
+           ((value & 0x001f) << 11);
+}
+
+static inline uint16_t
+r300_be_b5g6r5_cpu_to_gpu(uint16_t value)
+{
+    return util_bswap16(r300_b5g6r5_swap_rb(value));
+}
+
+static inline uint16_t
+r300_be_b5g6r5_gpu_to_cpu(uint16_t value)
+{
+    return r300_b5g6r5_swap_rb(util_bswap16(value));
+}
+
+static void
+r300_copy_b5g6r5_map(void *dst, unsigned dst_stride,
+                     const void *src, unsigned src_stride,
+                     unsigned width, unsigned height, unsigned depth,
+                     unsigned dst_layer_stride, unsigned src_layer_stride,
+                     bool cpu_to_gpu)
+{
+    unsigned z, y, x;
+
+    for (z = 0; z < depth; z++) {
+        const uint8_t *src_layer = (const uint8_t *)src + z * src_layer_stride;
+        uint8_t *dst_layer = (uint8_t *)dst + z * dst_layer_stride;
+
+        for (y = 0; y < height; y++) {
+            const uint16_t *src_row = (const uint16_t *)(src_layer + y * src_stride);
+            uint16_t *dst_row = (uint16_t *)(dst_layer + y * dst_stride);
+
+            for (x = 0; x < width; x++) {
+                dst_row[x] = cpu_to_gpu ?
+                    r300_be_b5g6r5_cpu_to_gpu(src_row[x]) :
+                    r300_be_b5g6r5_gpu_to_cpu(src_row[x]);
+            }
+        }
+    }
+}
