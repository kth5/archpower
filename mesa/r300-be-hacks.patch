+    if (!*index_buffer || !indices32) {
+        return false;
+    }
+
+    for (unsigned i = 0; i < count; ++i) {
+        indices32[i] = indices[i];
+    }
+#else
+    *index_size = 2;
+    u_upload_data_ref(r300->uploader, 0, count * sizeof(*indices), 4, indices,
+                      index_buffer_offset, index_buffer);
+
+    if (!*index_buffer) {
+        return false;
+    }
+#endif
+
+    return true;
+}
