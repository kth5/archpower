pkgname=lld
pkgver=22.1.7
pkgrel=1
pkgdesc="Linker from the LLVM project"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url="https://lld.llvm.org/"
license=('Apache-2.0 WITH LLVM-exception')
depends=('llvm-libs' 'libstdc++' 'glibc' 'zlib' 'zstd' )
makedepends=('llvm' 'cmake' 'ninja' 'python-sphinx')
_source_base=https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver
source=($_source_base/llvm-project-$pkgver.src.tar.xz{,.sig}
       hotfix-abi-powerpc64-elfv2.patch
       espresso-cpu.patch
       hotfix-abi-powerpc64-elfv2.patch
       hotfix-powerpc-pwr.patch
       hotfix-ppc-cell.patch
       hotfix-ppc-jit.patch)
sha256sums=('5cc4a3f12bba50b6bdfb4b61bdc852117a0ff2517807c3902fc13267fb93562e'
            'SKIP'
            '493d6807f28ad11b36dac60da0a8ae0e4d349c520c84af8e59b996e3c63c6d70'
            'e697985caba1841afca60af4c6598ab77abe12a5b7cd6e1b491270e53a499ce3'
            '493d6807f28ad11b36dac60da0a8ae0e4d349c520c84af8e59b996e3c63c6d70'
            '32738b977de98c620918a94dd01534ccae8f70310bd1c67730631b3dad759a26'
            'fdf9de5464870f78fbaa4ce158d1b7b7f9aa5cb73d6808c51e5c7c81253c9d48'
            '44251ca1f9bddd333c70604455af8553c27b2b27674f01dfdfe3e8926a00a24c')
validpgpkeys=('474E22316ABF4785A88C6E8EA2C794A986419D8A'  # Tom Stellard <tstellar@redhat.com>
              'D574BD5D1D0E98895E3BF90044F2485E45D59042'  # Tobias Hieta <tobias@hieta.se>
              'FFB3368980F3E6BB5737145A316C56D064CACBA5'  # Douglas Yung <douglas.yung@sony.com>
