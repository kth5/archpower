pkgname=vimb
pkgver=3.7.1
pkgrel=1
pkgdesc='The vim like browser'
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url=https://fanglingsu.github.io/vimb/
license=(GPL3)
depends=(webkit2gtk-4.1)
makedepends=(git)
_tag=448e7e2e66471b4cbfa8f373bb4bd7d7134cafaa
source=(git+https://github.com/fanglingsu/vimb.git#tag=${_tag})
b2sums=('545f2244f1bc18a5e875fe9009f2cce0ecd07cfb8d1f40538fad9ce60bcc5388511e6e0c89cbfb133c1fd6f209fe3516a237e9fe9eb2d2ed0217c6f7abba487b')

pkgver() {
  cd vimb
  git describe --tags
}

build() {
  make PREFIX=/usr -C vimb
}

package() {
  make DESTDIR="${pkgdir}" PREFIX=/usr -C vimb install
}

