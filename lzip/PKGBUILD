pkgname=lzip
pkgver=1.26
pkgrel=1
pkgdesc="A lossless file compressor based on the LZMA algorithm"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url="https://www.nongnu.org/lzip/lzip.html"
license=('GPL-2.0-or-later')
depends=('glibc' 'libgcc' 'libstdc++')
source=("https://download.savannah.gnu.org/releases/$pkgname/$pkgname-$pkgver.tar.gz"{,.sig})
sha256sums=('641cf30961525cbe3b340cc883436c8854e9f5032f459f444de4782b621e6572'
            'SKIP')
validpgpkeys=('1E5AEE0B18C0DEB45D64AA0325B62C9821501AA0')  # Antonio Diaz Diaz <antonio@gnu.org>

build() {
  cd $pkgname-$pkgver
  ./configure --prefix=/usr CXXFLAGS="$CXXFLAGS" LDFLAGS="$LDFLAGS"
  make
}

package() {
  cd $pkgname-$pkgver
  make DESTDIR="$pkgdir" install{,-man}
}
