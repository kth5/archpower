@@ -11,12 +11,17 @@
 
 #if HAVE_NETTLE_MD5_H
 #include <nettle/md5.h>
+#include <nettle/version.h>
 
 typedef struct md5_ctx SquidMD5_CTX;
 
 #define SquidMD5Init(c)       md5_init((c))
 #define SquidMD5Update(c,b,l) md5_update((c), (l), (const uint8_t *)(b))
