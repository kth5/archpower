pkgname=xorg-setxkbmap
pkgver=1.3.5
pkgrel=1
pkgdesc='Set the keyboard using the X Keyboard Extension'
url='https://xorg.freedesktop.org/'
license=('HPND')
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
depends=('libxkbfile' 'libxrandr' 'libx11' 'glibc')
makedepends=('xorg-util-macros')
source=(${url}/releases/individual/app/setxkbmap-${pkgver}.tar.xz{,.sig})
sha512sums=('57a7e4c0331f81e6e61240f0da69d536e0838c46191f789b7b2ca3a6a5a3d0169a28b71e108bbcf8d24d10068c63a7f65eb9196a3774dbd8a00db9ecc0df46a0'
            'SKIP')
validpgpkeys=('3AB285232C46AE43D8E192F4DAB0F78EA6E7E2D2') # Alan Coopersmith <alan.coopersmith@oracle.com>
# validpgpkeys=('3C2C43D9447D5938EF4551EBE23B7E70B467F0BF') # Peter Hutterer (Who-T) <office@who-t.net>

groups=('xorg-apps' 'xorg')

build() {
	cd setxkbmap-${pkgver}
	./configure --prefix=/usr
	make
}

package() {
	cd setxkbmap-${pkgver}
	make DESTDIR="${pkgdir}" install
	install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
