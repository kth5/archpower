pkgname=libcbor
pkgver=0.13.0
pkgrel=1
pkgdesc='C library for parsing and generating CBOR, the general-purpose schema-less binary data format'
url='https://github.com/PJK/libcbor'
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
license=('MIT')
depends=('glibc')
makedepends=(
  'cmake'
  'cmocka'
)
provides=('libcbor.so')
source=("${url}/archive/v${pkgver}/${pkgname}-${pkgver}.tar.gz")
sha512sums=('4b41f3c55de0169a60cbd353694c741c3db32d6a173feb1cb14022a7daf8511fc32befbaff7133903ea005df3db02e8ebd67881dff2cfdb89a5e51203b03fe4f')
b2sums=('80ca4bd1b8ad13689b1e556f72ced63358cd920f258723ebe37fc94a61d2abbf8b0f42cc5e4770b283acb9a542b9e7f37de92a032301c24e09ee448a18b3d634')

build() {
  cmake -S ${pkgname}-${pkgver} -B build \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -Wno-dev \
    -DBUILD_SHARED_LIBS=ON \
    -DWITH_TESTS=1
  cmake --build build
}

check() {
  ctest --test-dir build --output-on-failure
}

package() {
  DESTDIR="${pkgdir}" cmake --install build
  cd "${pkgname}-${pkgver}"
  install -vDm 644 -t "${pkgdir}/usr/share/doc/${pkgname}" README.md CHANGELOG.md
  install -vDm 644 -t "${pkgdir}/usr/share/licenses/${pkgname}" LICENSE.md
}
