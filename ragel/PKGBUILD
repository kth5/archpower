pkgname=ragel
pkgver=7.0.4
pkgrel=1
pkgdesc="Compiles finite state machines from regular languages into executable C, C++, Objective-C, or D code"
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
url="https://www.colm.net/open-source/ragel/"
license=('MIT')
depends=(
  'colm'
  'glibc'
  'libgcc'
  'libstdc++'
)
makedepends=(
  'asciidoc'
  'dblatex'
  'fig2dev'
  'python-pygments'
  'texlive-bin'
)
provides=('libragel.so')
source=(
  "https://www.colm.net/files/ragel/$pkgname-$pkgver.tar.gz"{,.asc}
  "$pkgname-fallback-no-la.patch::https://github.com/adrian-thurston/ragel/commit/463f4914057b0193c6ca025e9233c17035bc0448.patch"
)
b2sums=('d96444f6b8dc356b9effa6c5032952ffb2526833f90fcb63c7f6c293a73a70ba057995426ba789d237c61dee5e3aa1ab53ec3193bd31c9c4b994193910219d13'
        'SKIP'
        'bbe947d1daa0ad6c8c455d56e4ae49d7d0ae9624b4a6ea2e45d590d03d3f9ca1965a08ecb765b7b39a82e8259a4bc735bee34435454cc7ed05361dda743ed054')
validpgpkeys=(C3260F001EE3780F1BC3D4F650FE47277DC196FB) # Adrian Thurston <thurston@cs.queensu.ca>

prepare() {
  cd $pkgname-$pkgver
  patch -Np1 < ../$pkgname-fallback-no-la.patch

  # Fix test segfaults: const char buffer is placed in read-only memory but
  # used as a writable NFA stack, causing segfaults with modern toolchains.
  sed -i 's/^const char s\[4096\];/char s[4096];/' test/ragel.d/{genrep{1,2,5,6,7,8},nfa3}.rl

  autoreconf -fiv
}

build() {
  cd $pkgname-$pkgver
  ./configure --prefix=/usr --with-colm=/usr
  make
}

check() {
  case "${CARCH}" in
    powerpc*) return 0 ;;
  esac

  cd $pkgname-$pkgver/test
  ./runtests
}

package() {
  cd $pkgname-$pkgver
  make DESTDIR="$pkgdir" install
  install -vDm644 -t "$pkgdir/usr/share/vim/vimfiles/syntax" ragel.vim
  install -vDm644 -t "$pkgdir/usr/share/licenses/$pkgname" COPYING
}
