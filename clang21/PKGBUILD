#}

_python_optimize() {
  python -m compileall "$@"
  python -O -m compileall "$@"
  python -OO -m compileall "$@"
}

package() {
  cd clang-$pkgver.src/build

  DESTDIR="$pkgdir" ninja install-distribution
  install -Dm644 ../LICENSE.TXT "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  mv "$pkgdir"/usr/lib/{llvm21/lib/,}libclang-cpp.so.21.1
  ln -s ../../libclang-cpp.so.21.1 "$pkgdir/usr/lib/llvm21/lib/libclang-cpp.so.21.1"
  ln -s llvm21/lib/libclang.so.21.1 "$pkgdir"/usr/lib/libclang.so.21.1
}

