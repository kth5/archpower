pkgname=abiword
pkgver=3.0.8
pkgrel=1
pkgdesc='Fully-featured word processor'
arch=(x86_64 powerpc powerpc64 powerpc64le espresso)
url='https://gitlab.gnome.org/World/AbiWord'
license=(GPL-2.0-or-later)
depends=(
  at-spi2-core
  cairo
  enchant
  fontconfig
  fribidi
