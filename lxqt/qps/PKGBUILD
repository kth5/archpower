pkgname=qps
pkgver=2.13.0
pkgrel=1
pkgdesc="Qt process viewer and manager"
url="https://github.com/lxqt/qps"
depends=('hicolor-icon-theme' 'liblxqt' 'qt6-base')
makedepends=('lxqt-build-tools')
arch=(x86_64 powerpc64le powerpc64 powerpc espresso)
license=("GPL")
groups=("lxqt")
source=("https://github.com/lxqt/qps/releases/download/$pkgver/$pkgname-$pkgver.tar.xz"{,.asc})
sha256sums=('d6f236fcafe16611b88c468502665dd5e9c73aa18eae0666e8ca9062ef5a471e'
            'SKIP')
validpgpkeys=(
  "19DFDF3A579BD509DBB572D8BE793007AD22DF7E"  # https://github.com/tsujan.gpg
  "48836EB124A1EAAE695EDFEA229CA0A00A17D258"  # the key owned by an email used by https://github.com/stefonarch/, a long-time LXQt contributor, as per keys.openpgp.org
)

build() {
  cmake -B build -S "$srcdir/$pkgname-$pkgver" \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr
  make -C build
}

package() {
  cd build
  make DESTDIR="$pkgdir" install
}
