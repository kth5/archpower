# POWER Maintainer: Alexander Baldeck <alex.bldck@gmail.com>
# Contributor: e1z0 <justinas at eofnet dot lt>

_mod=amarok
_cat=applications/multimedia/
_kdemod="${_mod/tde/kde}"

pkgname="tde-${_mod}"
pkgver=14.1.6
pkgrel=1
pkgdesc="TDE Amarok"
arch=(i686 x86_64 aarch64 armv7h powerpc64le powerpc64 powerpc espresso)
url="https://scm.trinitydesktop.org/scm/git/${_mod}"
license=('GPL')
groups=('tde-extra')
depends=('tde-tdebase' 'taglib' 'xine-lib')
makedepends=('tde-cmake-trinity' 'tde-akode' 'ruby' 'libmtp' 'libvisual' 'sdl')
provides=("${_mod}")
conflicts=("trinity-${_mod}" "kdemod3-${_kdemod}")
replaces=("trinity-${_mod}")
options=('staticlibs' 'libtool' '!strip' '!debug')
source=("https://mirror.ppa.trinitydesktop.org/trinity/releases/R${pkgver}/main/${_cat}${_mod}-trinity-${pkgver}.tar.xz"
        "${pkgname}-${pkgver}-110-tq-atomic-strings.patch")
md5sums=('482d14d76a9831aac1cbb1a85c6e32e3'
         '22e6397f99be22421d73d6568c17dd78')
install=''

[ -n "$TDEDIR" ] || TDEDIR=/opt/trinity

prepare() {
  cd ${pkgname#*-}-trinity-${pkgver}
  patch -Np1 -i ${srcdir}/${pkgname}-${pkgver}-110-tq-atomic-strings.patch
}

build() {
   # kill massive amounts of warnings
   export CXXFLAGS+=' -Wno-deprecated-enum-enum-conversion -Wno-deprecated-declarations'

   msg "Creating out-of-source build directory: ${srcdir}/build"
   mkdir -p ${srcdir}/build
   cd ${srcdir}/build

   export PKG_CONFIG_PATH=${TDEDIR}/lib/pkgconfig:${PKG_CONFIG_PATH}

   msg "Starting cmake..."
   cmake ${srcdir}/${pkgname#*-}-trinity-${pkgver} \
     -GNinja \
     -DCMAKE_VERBOSE_MAKEFILE=ON \
     -DCMAKE_INSTALL_PREFIX=${TDEDIR} \
     -DBUILD_ALL=ON \
     -DWITH_ALL_OPTIONS=ON \
     -DWITH_YAUAP=OFF \
     -DWITH_NJB=OFF \
     -DWITH_IFP=OFF \
     -DWITH_IPOD=OFF \
     -DWITH_EMBEDDED_SQLITE=ON \
     -DWITH_SYSTEM_SQLITE=OFF \
     -DWITH_MYSQL=OFF \
     -DWITH_POSTGRESQL=OFF \
     -DWITH_AMAZON=OFF

   msg "Building - ${pkgname#*-}..."
   ninja $NUMJOBS
}

package() {
  msg "Packaging - $pkgname-$pkgver"
  cd ${srcdir}/build
  DESTDIR="${pkgdir}" ninja -j1 install
}
